TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Set to any truthy value to enable the two-way listener feature
# LISTENER_ENABLED=true
# Get your user ID by messaging @userinfobot on Telegram
# ALLOWED_USER_IDS=your_telegram_user_id
# Required for the classifier (safe-inject.ts calls /home/prei/bin/z-claude)
# MY_ZAI_AUTH_TOKEN=your_zai_token_here
# TTL for stale topic cleanup in ms (default: 14400000 = 4 hours)
# TOPIC_TTL_MS=14400000
